# Copy this file to `android/key.properties` and fill in your release keystore
# details to sign Play Store builds. NEVER commit the real key.properties or the
# .jks/.keystore file.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore ~/sangam-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias sangam
#
storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=sangam
# Absolute path to your keystore file, e.g. /Users/you/sangam-release.jks
storeFile=/absolute/path/to/sangam-release.jks
